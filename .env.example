# Local Docker MySQL env example
MYSQL_ROOT_PASSWORD=example_root_pw
MYSQL_DATABASE=tfowebapp
MYSQL_USER=tfo
MYSQL_PASSWORD=tfo_pass
MYSQL_PORT=3306
# When running services inside Docker, other services can use the service name `db`
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=tfo
DB_PASSWORD=tfo_pass
DB_NAME=tfowebapp

# Database-independent recovery login for /init.html and /init/*
# Set both to deployment-specific values; there are deliberately no defaults.
INIT_ADMIN_USERNAME=
INIT_ADMIN_PASSWORD=
